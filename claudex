#!/usr/bin/env bash
set -euo pipefail

CLAUDEX_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudex"
CLAUDEX_ENV_FILE="${CLAUDEX_CONFIG_DIR}/.env"
CLAUDEX_PRESETS_DIR="${CLAUDEX_PRESETS_DIR:-$(cd "$(dirname "$0")" && pwd)/presets}"

# Dependency checks
if ! command -v claude &>/dev/null; then
  echo "error: claude CLI not found. Install: https://docs.anthropic.com/en/docs/claude-code" >&2
  exit 1
fi

if ! command -v dotenvx &>/dev/null; then
  echo "error: dotenvx not found. Install: https://dotenvx.com/docs/install" >&2
  exit 1
fi

# Setup mode
if [[ "${1:-}" == "--setup" ]]; then
  preset_name="${2:-}"

  # List presets when no name given
  if [[ -z "$preset_name" ]]; then
    echo "Usage: claudex --setup <preset>"
    echo ""
    echo "Available presets:"
    for f in "$CLAUDEX_PRESETS_DIR"/*.env; do
      [[ -f "$f" ]] || continue
      name="$(basename "$f" .env)"
      desc="$(grep -m1 '^#' "$f" | sed 's/^# *//')"
      printf "  %-12s %s\n" "$name" "$desc"
    done
    exit 0
  fi

  preset_file="${CLAUDEX_PRESETS_DIR}/${preset_name}.env"
  if [[ ! -f "$preset_file" ]]; then
    echo "error: unknown preset '${preset_name}'" >&2
    echo "Run 'claudex --setup' to see available presets." >&2
    exit 1
  fi

  mkdir -p "$CLAUDEX_CONFIG_DIR"
  if [[ -f "$CLAUDEX_ENV_FILE" ]]; then
    if [[ -t 0 ]]; then
      echo "Config already exists at $CLAUDEX_ENV_FILE"
      read -rp "Overwrite? [y/N] " answer
      [[ "$answer" != [yY] ]] && exit 0
    fi
    rm -f "$CLAUDEX_ENV_FILE" "${CLAUDEX_CONFIG_DIR}/.env.keys"
  fi

  # Collect key-value pairs in memory, then write encrypted via dotenvx set.
  # Plaintext secrets never touch the filesystem.
  declare -a kv_keys=()
  declare -a kv_values=()
  declare -a kv_secret=()  # "1" = encrypt, "0" = plain

  while IFS= read -r line; do
    [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue
    key="${line%%=*}"
    value="${line#*=}"

    if [[ "$value" == "__secret__" ]]; then
      env_value="${!key:-}"
      if [[ -n "$env_value" ]]; then
        resolved="$env_value"
      elif [[ -t 0 ]]; then
        read -rp "${key}: " -s resolved
        echo
        [[ -z "$resolved" ]] && echo "error: ${key} is required" >&2 && exit 1
      else
        echo "error: ${key} is required (set it as an environment variable)" >&2 && exit 1
      fi
      kv_keys+=("$key"); kv_values+=("$resolved"); kv_secret+=("1")
    elif [[ "$value" == "__prompt__" ]]; then
      env_value="${!key:-}"
      if [[ -n "$env_value" ]]; then
        resolved="$env_value"
      elif [[ -t 0 ]]; then
        read -rp "${key}: " resolved
        [[ -z "$resolved" ]] && echo "error: ${key} is required" >&2 && exit 1
      else
        echo "error: ${key} is required (set it as an environment variable)" >&2 && exit 1
      fi
      kv_keys+=("$key"); kv_values+=("$resolved"); kv_secret+=("0")
    elif [[ "$value" =~ ^__prompt:(.*)__$ ]]; then
      default="${BASH_REMATCH[1]}"
      env_value="${!key:-}"
      if [[ -n "$env_value" ]]; then
        resolved="$env_value"
      elif [[ -t 0 ]]; then
        read -rp "${key} [${default}]: " user_value
        resolved="${user_value:-$default}"
      else
        resolved="$default"
      fi
      [[ -n "$resolved" ]] && { kv_keys+=("$key"); kv_values+=("$resolved"); kv_secret+=("0"); }
    else
      kv_keys+=("${line%%=*}"); kv_values+=("${line#*=}"); kv_secret+=("0")
    fi
  done < "$preset_file"

  # Initialize empty .env file for dotenvx set to operate on.
  touch "$CLAUDEX_ENV_FILE"

  # Write all values via dotenvx set — secrets are encrypted, others are plain.
  for i in "${!kv_keys[@]}"; do
    if [[ "${kv_secret[$i]}" == "1" ]]; then
      dotenvx set "${kv_keys[$i]}" "${kv_values[$i]}" -f "$CLAUDEX_ENV_FILE" --quiet
    else
      dotenvx set "${kv_keys[$i]}" "${kv_values[$i]}" -f "$CLAUDEX_ENV_FILE" --plain --quiet
    fi
  done

  chmod 600 "$CLAUDEX_ENV_FILE"
  [[ -f "${CLAUDEX_CONFIG_DIR}/.env.keys" ]] && chmod 600 "${CLAUDEX_CONFIG_DIR}/.env.keys"
  echo "Config written to $CLAUDEX_ENV_FILE (encrypted, preset: ${preset_name})"
  [[ -f "${CLAUDEX_CONFIG_DIR}/.env.keys" ]] && echo "Decryption key: ${CLAUDEX_CONFIG_DIR}/.env.keys (keep this safe)"
  exit 0
fi

if [[ ! -f "$CLAUDEX_ENV_FILE" ]]; then
  echo "error: $CLAUDEX_ENV_FILE not found. Run: claudex --setup" >&2
  exit 1
fi

exec env -u DOTENV_PRIVATE_KEY dotenvx run --quiet --env-file "$CLAUDEX_ENV_FILE" -fk "${CLAUDEX_CONFIG_DIR}/.env.keys" -- claude "$@"
