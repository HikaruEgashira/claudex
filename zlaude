#!/usr/bin/env bash
set -euo pipefail

ZLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zlaude"
ZLAUDE_ENV_FILE="${ZLAUDE_CONFIG_DIR}/.env"
ZLAUDE_PRESETS_DIR="${ZLAUDE_PRESETS_DIR:-$(cd "$(dirname "$0")" && pwd)/presets}"

# Dependency checks
if ! command -v claude &>/dev/null; then
  echo "error: claude CLI not found. Install: https://docs.anthropic.com/en/docs/claude-code" >&2
  exit 1
fi

if ! command -v dotenvx &>/dev/null; then
  echo "error: dotenvx not found. Install: https://dotenvx.com/docs/install" >&2
  exit 1
fi

# Setup mode
if [[ "${1:-}" == "--setup" ]]; then
  preset_name="${2:-}"

  # List presets when no name given
  if [[ -z "$preset_name" ]]; then
    echo "Usage: zlaude --setup <preset>"
    echo ""
    echo "Available presets:"
    for f in "$ZLAUDE_PRESETS_DIR"/*.env; do
      [[ -f "$f" ]] || continue
      name="$(basename "$f" .env)"
      url="$(grep -m1 '^ANTHROPIC_BASE_URL=' "$f" | cut -d= -f2-)"
      model="$(grep -m1 '^ANTHROPIC_DEFAULT_MODEL=' "$f" | cut -d= -f2-)"
      printf "  %-12s %s (%s)\n" "$name" "$url" "$model"
    done
    exit 0
  fi

  preset_file="${ZLAUDE_PRESETS_DIR}/${preset_name}.env"
  if [[ ! -f "$preset_file" ]]; then
    echo "error: unknown preset '${preset_name}'" >&2
    echo "Run 'zlaude --setup' to see available presets." >&2
    exit 1
  fi

  # Read preset values
  base_url="$(grep -m1 '^ANTHROPIC_BASE_URL=' "$preset_file" | cut -d= -f2-)"
  model="$(grep -m1 '^ANTHROPIC_DEFAULT_MODEL=' "$preset_file" | cut -d= -f2-)"

  mkdir -p "$ZLAUDE_CONFIG_DIR"
  if [[ -f "$ZLAUDE_ENV_FILE" ]]; then
    echo "Config already exists at $ZLAUDE_ENV_FILE"
    read -rp "Overwrite? [y/N] " answer
    [[ "$answer" != [yY] ]] && exit 0
  fi

  read -rp "ANTHROPIC_AUTH_TOKEN: " -s auth_token
  echo
  if [[ -z "$auth_token" ]]; then
    echo "error: auth token is required" >&2
    exit 1
  fi

  cat > "$ZLAUDE_ENV_FILE" <<EOF
ANTHROPIC_AUTH_TOKEN=${auth_token}
ANTHROPIC_BASE_URL=${base_url}
API_TIMEOUT_MS=3000000
ANTHROPIC_DEFAULT_OPUS_MODEL=${model}
ANTHROPIC_DEFAULT_SONNET_MODEL=${model}
ANTHROPIC_DEFAULT_HAIKU_MODEL=${model}
EOF
  chmod 600 "$ZLAUDE_ENV_FILE"
  echo "Config written to $ZLAUDE_ENV_FILE (preset: ${preset_name})"
  exit 0
fi

if [[ ! -f "$ZLAUDE_ENV_FILE" ]]; then
  echo "error: $ZLAUDE_ENV_FILE not found. Run: zlaude --setup" >&2
  exit 1
fi

exec dotenvx run --quiet --env-file "$ZLAUDE_ENV_FILE" -- claude "$@"
